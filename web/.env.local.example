# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.
# NEVER commit real secrets. Public values are prefixed NEXT_PUBLIC_ (exposed to the browser);
# everything else is server-only and must stay secret.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key   # SECRET — bypasses RLS, full DB access

# --- Anthropic (for the tutor / AI features) ---
ANTHROPIC_API_KEY=sk-ant-...                  # SECRET

# --- Arena (live order-book server) ---
# wss:// in production (browsers block ws:// from an https page). Default dev: ws://localhost:8765
NEXT_PUBLIC_ARENA_URL=ws://localhost:8765

# --- Sentry (error monitoring; optional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                            # SECRET
SENTRY_ORG=
SENTRY_PROJECT=

# --- Discord (notifications webhook; optional) ---
DISCORD_WEBHOOK_URL=                          # SECRET
